# ─── Backend (server-side only — never use NEXT_PUBLIC_ for secrets) ───
COPILOT_API_KEY=your-secret-key
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...

# ─── Frontend ───
# Internal URL the Next.js API route uses to reach the backend
BACKEND_URL=http://localhost:8000

# Public WebSocket URL the browser connects to (non-sensitive, endpoint only)
NEXT_PUBLIC_WS_URL=ws://localhost:8000
